# Sentinel — environment template.
#
# Copy this file to ".env" and fill in your key to enable the AI Advisor Briefing.
# Nothing here is required to RUN the app: with no key set, the briefing and
# "ask the data" fall back to a deterministic, rule-generated memo. The .env file
# is git-ignored; this .env.example is committed as documentation.
#
#   cp .env.example .env   # then edit .env

# OpenAI API key — enables the AI briefing + ask-the-data. Leave blank for fallback.
OPENAI_API_KEY=

# Optional: which OpenAI chat model to use (default: gpt-4o-mini).
# OPENAI_MODEL=gpt-4o

# Optional: comma-separated CORS origins for the API (default: the Vite dev server).
# VFIN_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
